# ============================================
# 数据资产管理平台 — 后端环境变量
# 部署时复制为 backend/.env 并填入实际值
# ============================================

# PostgreSQL 连接串 (psycopg driver)
APP_DB_URL=postgresql+psycopg://asset_app:REPLACE_WITH_PASSWORD@127.0.0.1:5432/data_asset

# CORS 允许的来源 (JSON 数组)
APP_CORS_ORIGINS=["http://10.10.8.83","http://localhost:8848"]

# 凭据加密密钥 (Feret 密钥, 需 32 字符随机串)
APP_CREDENTIAL_ENCRYPT_KEY=REPLACE_WITH_SECURE_KEY

# 快照保留天数
APP_SNAPSHOT_RETENTION_DAYS=90

# 事件日志保留天数
APP_EVENT_RETENTION_DAYS=365

# 定时调度器时区
APP_SCHEDULER_TIMEZONE=Asia/Shanghai
